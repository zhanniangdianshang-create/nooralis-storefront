PORT=3000
PUBLIC_BASE_URL=https://nooraliswings.com

# Checkout provider:
# - hosted_link: external hosted checkout such as Oceanpayment Payment Links
# - paypal: PayPal REST checkout
# - manual: disable online payment button and send buyers to quote/invoice flow
CHECKOUT_PROVIDER=hosted_link
CHECKOUT_PROVIDER_NAME=Oceanpayment Card Checkout
CHECKOUT_ACTION_LABEL=Pay by Credit / Debit Card
HOSTED_CHECKOUT_URL=
HOSTED_CHECKOUT_SINGLE_UNIT_ONLY=true
CHECKOUT_BADGES=Visa|Mastercard|Apple Pay|Google Pay
CHECKOUT_NOTE=Secure credit and debit card checkout for one-kit online payments. For 2+ kits, urgent shows, or custom finishes, use the quote form below.
ORDER_DASHBOARD_PASSWORD=choose_a_private_dashboard_password

# Optional PayPal REST app credentials from developer.paypal.com.
# Only needed when CHECKOUT_PROVIDER=paypal.
PAYPAL_ENVIRONMENT=live
PAYPAL_CLIENT_ID=your_live_paypal_client_id
PAYPAL_CLIENT_SECRET=your_live_paypal_secret

PRODUCT_NAME=Nooralis LED Bionic Butterfly Drone
PRODUCT_PRICE_CENTS=34900
PRODUCT_CURRENCY=usd

# On Vercel, BLOB_READ_WRITE_TOKEN is added automatically when you connect a Blob store.
